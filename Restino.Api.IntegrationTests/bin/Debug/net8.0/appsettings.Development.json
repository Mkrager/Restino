{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "RestinoConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=RestinoDb;Trusted_Connection=True;",
    "RestinoIdentityConnectionString": "Server=(localdb)\\MSSQLLocalDB;Database=RestinoIdentityDb;Trusted_Connection=True;"
  },
  "AllowedHosts": "*",
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    },
    "Filter": [
      {
        "Name": "ByExcluding",
        "Args": { "expression": "@mt = 'An unhandled exception has occurred while executing the request.'" }
      }
    ],
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "./logs/log-.txt",
          "rollingInterval": "Day"
        }
      }
    ]
  },
  "JwtSettings": {
    "Key": "73AE92E6113F4369A713A94C5A9C6B15",
    "Issuer": "RestinoIdentity",
    "Audience": "RestinoIdentityUser",
    "DurationInMinutes": 60
  }
}
